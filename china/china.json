{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "zhu": "#C03530",
    "mingHuang": "#F9BA2C",
    "xingHuang": "#FF954B",
    "shiQing": "#63BBC8",
    "shiLu": "#74BC9C",
    "zi": "#605D9D",
    "yuSe": "#BCCFA6",
    "zangLan": "#1C4A5C",
    "miBai": "#E9E3D4",
    "darkBg": "#171B24",
    "darkBgPanel": "#202731",
    "darkBgElement": "#29333D",
    "darkText": "#E9E3D4",
    "darkMuted": "#969B98",
    "darkBorder": "#748084",
    "darkBorderSubtle": "#35424C",
    "darkSecondary": "#AAA2DE",
    "darkError": "#F07A72",
    "darkWarning": "#FF9F5A",
    "lightBg": "#F6F1E8",
    "lightBgPanel": "#EDE6D9",
    "lightBgElement": "#E4DDCF",
    "lightText": "#35322E",
    "lightMuted": "#625D57",
    "lightBorder": "#807461",
    "lightBorderSubtle": "#D0C5B6",
    "lightPrimary": "#205F73",
    "lightSecondary": "#56508A",
    "lightAccent": "#765607",
    "lightError": "#A9322D",
    "lightWarning": "#884415",
    "lightSuccess": "#2C684C"
  },
  "theme": {
    "primary": { "dark": "shiQing", "light": "lightPrimary" },
    "secondary": { "dark": "darkSecondary", "light": "lightSecondary" },
    "accent": { "dark": "mingHuang", "light": "lightAccent" },
    "error": { "dark": "darkError", "light": "lightError" },
    "warning": { "dark": "darkWarning", "light": "lightWarning" },
    "success": { "dark": "shiLu", "light": "lightSuccess" },
    "info": { "dark": "shiQing", "light": "lightPrimary" },
    "text": { "dark": "darkText", "light": "lightText" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkBgElement", "light": "lightBgElement" },
    "border": { "dark": "darkBorder", "light": "lightBorder" },
    "borderActive": { "dark": "shiQing", "light": "lightPrimary" },
    "borderSubtle": { "dark": "darkBorderSubtle", "light": "lightBorderSubtle" },
    "diffAdded": { "dark": "shiLu", "light": "lightSuccess" },
    "diffRemoved": { "dark": "darkError", "light": "lightError" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "darkSecondary", "light": "lightSecondary" },
    "diffHighlightAdded": { "dark": "shiLu", "light": "lightSuccess" },
    "diffHighlightRemoved": { "dark": "darkError", "light": "lightError" },
    "diffAddedBg": { "dark": "#1D332C", "light": "#DFEADF" },
    "diffRemovedBg": { "dark": "#3B2426", "light": "#F0DEDB" },
    "diffContextBg": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "darkMuted", "light": "lightMuted" },
    "diffAddedLineNumberBg": { "dark": "#172B25", "light": "#CFDFD1" },
    "diffRemovedLineNumberBg": { "dark": "#302023", "light": "#E6D0CC" },
    "markdownText": { "dark": "darkText", "light": "lightText" },
    "markdownHeading": { "dark": "shiQing", "light": "lightPrimary" },
    "markdownLink": { "dark": "shiQing", "light": "lightPrimary" },
    "markdownLinkText": { "dark": "shiLu", "light": "lightSuccess" },
    "markdownCode": { "dark": "shiLu", "light": "lightSuccess" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "darkWarning", "light": "lightWarning" },
    "markdownStrong": { "dark": "mingHuang", "light": "lightAccent" },
    "markdownHorizontalRule": { "dark": "darkBorder", "light": "lightBorder" },
    "markdownListItem": { "dark": "mingHuang", "light": "lightAccent" },
    "markdownListEnumeration": { "dark": "shiQing", "light": "lightPrimary" },
    "markdownImage": { "dark": "shiQing", "light": "lightPrimary" },
    "markdownImageText": { "dark": "shiLu", "light": "lightSuccess" },
    "markdownCodeBlock": { "dark": "darkText", "light": "lightText" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "darkSecondary", "light": "lightSecondary" },
    "syntaxFunction": { "dark": "shiQing", "light": "lightPrimary" },
    "syntaxVariable": { "dark": "shiLu", "light": "lightSuccess" },
    "syntaxString": { "dark": "shiLu", "light": "lightSuccess" },
    "syntaxNumber": { "dark": "darkSecondary", "light": "lightSecondary" },
    "syntaxType": { "dark": "shiQing", "light": "lightPrimary" },
    "syntaxOperator": { "dark": "darkWarning", "light": "lightWarning" },
    "syntaxPunctuation": { "dark": "darkText", "light": "lightText" }
  }
}
