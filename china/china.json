{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "zhusha": "#C23531",
    "golden": "#D4A537",
    "indigo": "#2F4554",
    "bamboo": "#5B8C5A",
    "ink": "#1A1A2E",
    "ricepaper": "#F4EDE4",
    "plum": "#7C3A8C",
    "jade": "#5F9EA0",
    "lighterInk": "#35354D",
    "lighterPaper": "#E8DCCB",
    "darkPanel": "#1E1E2F",
    "darkElement": "#2A2A3E",
    "darkText": "#E8DCCB",
    "darkMuted": "#8B8680",
    "darkBorder": "#3D3D52",
    "darkBorderSubtle": "#2D2D42",
    "darkRed": "#D45A5A",
    "darkYellow": "#E6C35C",
    "darkGreen": "#7DB87D",
    "darkBlue": "#6FB3D2",
    "lightBg": "#FBF6EF",
    "lightBgPanel": "#F0E8DA",
    "lightBgElement": "#E8DCCB",
    "lightText": "#2C2C40",
    "lightMuted": "#6B6560",
    "lightBorder": "#C4B8A5",
    "lightBorderSubtle": "#DDD3C0",
    "lightRed": "#9E2E33",
    "lightYellow": "#8B6914",
    "lightGreen": "#3E6B3E",
    "lightBlue": "#2A7DA4",
    "lightPurple": "#6B2E7C",
    "lightCyan": "#1B7C80"
  },
  "theme": {
    "primary": { "dark": "golden", "light": "zhusha" },
    "secondary": { "dark": "indigo", "light": "indigo" },
    "accent": { "dark": "jade", "light": "jade" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkYellow", "light": "lightYellow" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkBlue", "light": "lightBlue" },
    "text": { "dark": "darkText", "light": "lightText" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "ink", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkElement", "light": "lightBgElement" },
    "border": { "dark": "darkBorder", "light": "lightBorder" },
    "borderActive": { "dark": "golden", "light": "zhusha" },
    "borderSubtle": { "dark": "darkBorderSubtle", "light": "lightBorderSubtle" },
    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "plum", "light": "lightPurple" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "#1F331F", "light": "#E0F0E0" },
    "diffRemovedBg": { "dark": "#3A1A1A", "light": "#F5E0E0" },
    "diffContextBg": { "dark": "darkPanel", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "darkMuted", "light": "lightMuted" },
    "diffAddedLineNumberBg": { "dark": "#142814", "light": "#CBE6CB" },
    "diffRemovedLineNumberBg": { "dark": "#2C1212", "light": "#E6C8C8" },
    "markdownText": { "dark": "darkText", "light": "lightText" },
    "markdownHeading": { "dark": "golden", "light": "zhusha" },
    "markdownLink": { "dark": "jade", "light": "jade" },
    "markdownLinkText": { "dark": "zhusha", "light": "lightCyan" },
    "markdownCode": { "dark": "bamboo", "light": "lightGreen" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "plum", "light": "lightPurple" },
    "markdownStrong": { "dark": "golden", "light": "zhusha" },
    "markdownHorizontalRule": { "dark": "darkBorder", "light": "lightBorder" },
    "markdownListItem": { "dark": "golden", "light": "zhusha" },
    "markdownListEnumeration": { "dark": "jade", "light": "jade" },
    "markdownImage": { "dark": "jade", "light": "jade" },
    "markdownImageText": { "dark": "zhusha", "light": "lightCyan" },
    "markdownCodeBlock": { "dark": "darkText", "light": "lightText" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "plum", "light": "lightPurple" },
    "syntaxFunction": { "dark": "golden", "light": "zhusha" },
    "syntaxVariable": { "dark": "zhusha", "light": "lightRed" },
    "syntaxString": { "dark": "bamboo", "light": "lightGreen" },
    "syntaxNumber": { "dark": "jade", "light": "lightCyan" },
    "syntaxType": { "dark": "golden", "light": "zhusha" },
    "syntaxOperator": { "dark": "lightGreen", "light": "lightCyan" },
    "syntaxPunctuation": { "dark": "darkText", "light": "lightText" }
  }
}
