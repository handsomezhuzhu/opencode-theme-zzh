{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "palaceRed": "#9D2933",
    "vermilion": "#C23531",
    "imperialGold": "#F2C14E",
    "glazedGold": "#FFD166",
    "jadeGreen": "#38664F",
    "glazedBlue": "#285F7A",
    "darkBg": "#1C090B",
    "darkBgPanel": "#350D12",
    "darkBgElement": "#54151B",
    "darkText": "#F8E8D0",
    "darkMuted": "#C9A38F",
    "darkBorder": "#B5794A",
    "darkBorderSubtle": "#6B2830",
    "darkRed": "#FF8A80",
    "darkError": "#FF6B6B",
    "darkGreen": "#83B89A",
    "darkBlue": "#7DB7D8",
    "lightBg": "#FBF3E6",
    "lightBgPanel": "#F5E5CF",
    "lightBgElement": "#EBD4B5",
    "lightText": "#2A1715",
    "lightMuted": "#6E514A",
    "lightBorder": "#8A5C40",
    "lightBorderSubtle": "#CFB797",
    "lightGold": "#7A5200",
    "lightRed": "#9D2933",
    "lightAccent": "#A3362F",
    "lightError": "#A61B29",
    "lightGreen": "#38664F",
    "lightBlue": "#285F7A"
  },
  "theme": {
    "primary": { "dark": "imperialGold", "light": "lightRed" },
    "secondary": { "dark": "darkRed", "light": "lightGold" },
    "accent": { "dark": "glazedGold", "light": "lightAccent" },
    "error": { "dark": "darkError", "light": "lightError" },
    "warning": { "dark": "imperialGold", "light": "lightGold" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkBlue", "light": "lightBlue" },
    "text": { "dark": "darkText", "light": "lightText" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkBgElement", "light": "lightBgElement" },
    "border": { "dark": "darkBorder", "light": "lightBorder" },
    "borderActive": { "dark": "imperialGold", "light": "lightRed" },
    "borderSubtle": { "dark": "darkBorderSubtle", "light": "lightBorderSubtle" },
    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkError", "light": "lightError" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "imperialGold", "light": "lightGold" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkError", "light": "lightError" },
    "diffAddedBg": { "dark": "#243529", "light": "#E3E9D9" },
    "diffRemovedBg": { "dark": "#4B171B", "light": "#F2D9D4" },
    "diffContextBg": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "darkMuted", "light": "lightMuted" },
    "diffAddedLineNumberBg": { "dark": "#1D2D22", "light": "#D4E0CC" },
    "diffRemovedLineNumberBg": { "dark": "#3E1216", "light": "#E9CBC5" },
    "markdownText": { "dark": "darkText", "light": "lightText" },
    "markdownHeading": { "dark": "imperialGold", "light": "lightRed" },
    "markdownLink": { "dark": "darkRed", "light": "lightRed" },
    "markdownLinkText": { "dark": "glazedGold", "light": "lightGold" },
    "markdownCode": { "dark": "darkGreen", "light": "lightGreen" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "darkRed", "light": "lightAccent" },
    "markdownStrong": { "dark": "glazedGold", "light": "lightGold" },
    "markdownHorizontalRule": { "dark": "darkBorder", "light": "lightBorder" },
    "markdownListItem": { "dark": "imperialGold", "light": "lightRed" },
    "markdownListEnumeration": { "dark": "darkRed", "light": "lightGold" },
    "markdownImage": { "dark": "darkRed", "light": "lightRed" },
    "markdownImageText": { "dark": "glazedGold", "light": "lightGold" },
    "markdownCodeBlock": { "dark": "darkText", "light": "lightText" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "darkRed", "light": "lightRed" },
    "syntaxFunction": { "dark": "imperialGold", "light": "lightGold" },
    "syntaxVariable": { "dark": "darkRed", "light": "lightAccent" },
    "syntaxString": { "dark": "darkGreen", "light": "lightGreen" },
    "syntaxNumber": { "dark": "glazedGold", "light": "lightGold" },
    "syntaxType": { "dark": "darkBlue", "light": "lightBlue" },
    "syntaxOperator": { "dark": "darkRed", "light": "lightAccent" },
    "syntaxPunctuation": { "dark": "darkText", "light": "lightText" }
  }
}
