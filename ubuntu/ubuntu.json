{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "ubuntuOrange": "#E95420",
    "ubuntuLightAubergine": "#77216F",
    "ubuntuMidAubergine": "#5E2750",
    "ubuntuDarkAubergine": "#2C001E",
    "ubuntuWarmGrey": "#AEA79F",
    "ubuntuCoolGrey": "#333333",
    "darkBgPanel": "#411934",
    "darkBgElement": "#56334B",
    "darkText": "#F6F6F5",
    "darkMuted": "#CABFC6",
    "darkBorder": "#806678",
    "darkBorderSubtle": "#6B4C61",
    "darkOrangeSoft": "#F4AA90",
    "darkPurpleSoft": "#CFB1CC",
    "darkRed": "#FA8790",
    "darkYellow": "#F5C96A",
    "darkGreen": "#77C59A",
    "darkBlue": "#75BCE8",
    "darkCyan": "#72D1C8",
    "lightBgPanel": "#F6F6F5",
    "lightBgElement": "#EEEDEB",
    "lightMuted": "#6F646B",
    "lightBorder": "#81767D",
    "lightBorderSubtle": "#E6DEE4",
    "lightOrange": "#B33608",
    "lightAubergine": "#5E2750",
    "lightRed": "#B52F3E",
    "lightYellow": "#765E00",
    "lightGreen": "#26734D",
    "lightBlue": "#176C9E",
    "lightCyan": "#1B7470",
    "lightPurple": "#77216F"
  },
  "theme": {
    "primary": { "dark": "darkOrangeSoft", "light": "lightOrange" },
    "secondary": { "dark": "darkPurpleSoft", "light": "ubuntuMidAubergine" },
    "accent": { "dark": "darkCyan", "light": "ubuntuLightAubergine" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkYellow", "light": "lightYellow" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkBlue", "light": "lightBlue" },
    "text": { "dark": "darkText", "light": "ubuntuCoolGrey" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "ubuntuDarkAubergine", "light": "#FFFFFF" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkBgElement", "light": "lightBgElement" },
    "border": { "dark": "darkBorder", "light": "lightBorder" },
    "borderActive": { "dark": "ubuntuOrange", "light": "lightOrange" },
    "borderSubtle": { "dark": "darkBorderSubtle", "light": "lightBorderSubtle" },
    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "darkOrangeSoft", "light": "ubuntuMidAubergine" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "#233D35", "light": "#E0F2E8" },
    "diffRemovedBg": { "dark": "#5A2433", "light": "#F9E2E5" },
    "diffContextBg": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "darkMuted", "light": "ubuntuMidAubergine" },
    "diffAddedLineNumberBg": { "dark": "#1C322B", "light": "#D1E8DC" },
    "diffRemovedLineNumberBg": { "dark": "#481D2A", "light": "#EFD3D7" },
    "markdownText": { "dark": "darkText", "light": "ubuntuCoolGrey" },
    "markdownHeading": { "dark": "ubuntuOrange", "light": "lightOrange" },
    "markdownLink": { "dark": "darkOrangeSoft", "light": "lightAubergine" },
    "markdownLinkText": { "dark": "darkCyan", "light": "lightCyan" },
    "markdownCode": { "dark": "darkGreen", "light": "lightGreen" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "darkYellow", "light": "lightYellow" },
    "markdownStrong": { "dark": "darkOrangeSoft", "light": "lightOrange" },
    "markdownHorizontalRule": { "dark": "darkBorder", "light": "lightBorder" },
    "markdownListItem": { "dark": "ubuntuOrange", "light": "lightOrange" },
    "markdownListEnumeration": { "dark": "darkPurpleSoft", "light": "lightPurple" },
    "markdownImage": { "dark": "darkOrangeSoft", "light": "lightAubergine" },
    "markdownImageText": { "dark": "darkCyan", "light": "lightCyan" },
    "markdownCodeBlock": { "dark": "darkText", "light": "ubuntuCoolGrey" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "darkPurpleSoft", "light": "lightPurple" },
    "syntaxFunction": { "dark": "darkOrangeSoft", "light": "lightOrange" },
    "syntaxVariable": { "dark": "darkOrangeSoft", "light": "ubuntuMidAubergine" },
    "syntaxString": { "dark": "darkGreen", "light": "lightGreen" },
    "syntaxNumber": { "dark": "darkYellow", "light": "lightYellow" },
    "syntaxType": { "dark": "darkBlue", "light": "lightBlue" },
    "syntaxOperator": { "dark": "darkCyan", "light": "lightCyan" },
    "syntaxPunctuation": { "dark": "darkText", "light": "ubuntuCoolGrey" }
  }
}
