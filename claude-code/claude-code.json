{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "anthropicAccent": "#C6613F",
    "claudeClay": "#D97757",
    "cloudDark": "#87867F",
    "cloudMedium": "#B0AEA5",
    "cloudLight": "#D1CFC5",
    "coral": "#EBCECE",
    "fig": "#C46686",
    "heather": "#CBCADB",
    "ivoryDark": "#E8E6DC",
    "ivoryMedium": "#F0EEE6",
    "kraft": "#D4A27F",
    "manilla": "#EBDBBC",
    "olive": "#788C5D",
    "slateDark": "#141413",
    "slateLight": "#5E5D59",
    "slateMedium": "#3D3D3A",
    "darkBgPanel": "#222220",
    "darkBgElement": "#292927",
    "darkFig": "#D990AA",
    "darkOlive": "#A5B98C",
    "darkError": "#E88875",
    "darkBorder": "#87867F",
    "darkBorderSubtle": "#3D3D3A",
    "lightClay": "#A7472A",
    "lightFig": "#8A3858",
    "lightKraft": "#7D573B",
    "lightOlive": "#4F653A",
    "lightError": "#9A3E35",
    "lightInfo": "#3F5F87",
    "lightBorder": "#7E7D76"
  },
  "theme": {
    "primary": { "dark": "claudeClay", "light": "lightClay" },
    "secondary": { "dark": "darkFig", "light": "lightFig" },
    "accent": { "dark": "kraft", "light": "lightKraft" },
    "error": { "dark": "darkError", "light": "lightError" },
    "warning": { "dark": "manilla", "light": "lightKraft" },
    "success": { "dark": "darkOlive", "light": "lightOlive" },
    "info": { "dark": "heather", "light": "lightInfo" },
    "text": { "dark": "ivoryMedium", "light": "slateDark" },
    "textMuted": { "dark": "cloudMedium", "light": "slateLight" },
    "background": { "dark": "slateDark", "light": "ivoryMedium" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "#FFFFFF" },
    "backgroundElement": { "dark": "darkBgElement", "light": "ivoryDark" },
    "border": { "dark": "darkBorder", "light": "lightBorder" },
    "borderActive": { "dark": "claudeClay", "light": "lightClay" },
    "borderSubtle": { "dark": "darkBorderSubtle", "light": "cloudLight" },
    "diffAdded": { "dark": "darkOlive", "light": "lightOlive" },
    "diffRemoved": { "dark": "darkError", "light": "lightError" },
    "diffContext": { "dark": "cloudMedium", "light": "slateLight" },
    "diffHunkHeader": { "dark": "heather", "light": "lightInfo" },
    "diffHighlightAdded": { "dark": "darkOlive", "light": "lightOlive" },
    "diffHighlightRemoved": { "dark": "darkError", "light": "lightError" },
    "diffAddedBg": { "dark": "#243026", "light": "#E5ECDF" },
    "diffRemovedBg": { "dark": "#382522", "light": "#F2E0DB" },
    "diffContextBg": { "dark": "darkBgPanel", "light": "ivoryDark" },
    "diffLineNumber": { "dark": "cloudMedium", "light": "slateLight" },
    "diffAddedLineNumberBg": { "dark": "#2C3B2E", "light": "#D8E4D1" },
    "diffRemovedLineNumberBg": { "dark": "#452B27", "light": "#EACFC8" },
    "markdownText": { "dark": "ivoryMedium", "light": "slateDark" },
    "markdownHeading": { "dark": "claudeClay", "light": "lightClay" },
    "markdownLink": { "dark": "heather", "light": "lightInfo" },
    "markdownLinkText": { "dark": "claudeClay", "light": "lightClay" },
    "markdownCode": { "dark": "darkOlive", "light": "lightOlive" },
    "markdownBlockQuote": { "dark": "cloudMedium", "light": "slateLight" },
    "markdownEmph": { "dark": "darkFig", "light": "lightFig" },
    "markdownStrong": { "dark": "kraft", "light": "lightKraft" },
    "markdownHorizontalRule": { "dark": "darkBorder", "light": "lightBorder" },
    "markdownListItem": { "dark": "claudeClay", "light": "lightClay" },
    "markdownListEnumeration": { "dark": "heather", "light": "lightInfo" },
    "markdownImage": { "dark": "heather", "light": "lightInfo" },
    "markdownImageText": { "dark": "claudeClay", "light": "lightClay" },
    "markdownCodeBlock": { "dark": "ivoryMedium", "light": "slateDark" },
    "syntaxComment": { "dark": "cloudMedium", "light": "slateLight" },
    "syntaxKeyword": { "dark": "darkFig", "light": "lightFig" },
    "syntaxFunction": { "dark": "claudeClay", "light": "lightClay" },
    "syntaxVariable": { "dark": "ivoryMedium", "light": "slateDark" },
    "syntaxString": { "dark": "darkOlive", "light": "lightOlive" },
    "syntaxNumber": { "dark": "kraft", "light": "lightKraft" },
    "syntaxType": { "dark": "heather", "light": "lightInfo" },
    "syntaxOperator": { "dark": "claudeClay", "light": "lightClay" },
    "syntaxPunctuation": { "dark": "ivoryMedium", "light": "slateDark" }
  }
}
