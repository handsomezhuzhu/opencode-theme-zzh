{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "brandYellow": "#FCEE0A",
    "uiRed": "#F75049",
    "uiCyan": "#5EF6FF",
    "successMint": "#1DED83",
    "warningOrange": "#FB932E",
    "questGold": "#F0B537",
    "typeBlue": "#86B7FF",
    "darkBg": "#0E0E17",
    "darkBgPanel": "#171720",
    "darkBgElement": "#20202B",
    "darkText": "#D6D0D0",
    "darkMuted": "#8B878E",
    "darkBorder": "#706C76",
    "darkBorderSubtle": "#343440",
    "darkError": "#FF5C53",
    "lightBg": "#FFFFFF",
    "lightBgPanel": "#FFFDE7",
    "lightBgElement": "#F4F1F1",
    "lightText": "#0E0E17",
    "lightMuted": "#5B5861",
    "lightBorder": "#8B878E",
    "lightBorderSubtle": "#D6D0D0",
    "lightRed": "#98322B",
    "lightCyan": "#006E76",
    "lightYellow": "#6A5200",
    "lightError": "#A0002A",
    "lightOrange": "#8A4600",
    "lightGreen": "#006F3D",
    "lightBlue": "#1D5AB3"
  },
  "theme": {
    "primary": { "dark": "uiRed", "light": "lightRed" },
    "secondary": { "dark": "uiCyan", "light": "lightCyan" },
    "accent": { "dark": "brandYellow", "light": "lightYellow" },
    "error": { "dark": "darkError", "light": "lightError" },
    "warning": { "dark": "warningOrange", "light": "lightOrange" },
    "success": { "dark": "successMint", "light": "lightGreen" },
    "info": { "dark": "uiCyan", "light": "lightCyan" },
    "text": { "dark": "darkText", "light": "lightText" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkBgElement", "light": "lightBgElement" },
    "border": { "dark": "darkBorder", "light": "lightBorder" },
    "borderActive": { "dark": "uiCyan", "light": "lightCyan" },
    "borderSubtle": { "dark": "darkBorderSubtle", "light": "lightBorderSubtle" },
    "diffAdded": { "dark": "successMint", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkError", "light": "lightError" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "uiCyan", "light": "lightCyan" },
    "diffHighlightAdded": { "dark": "successMint", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkError", "light": "lightError" },
    "diffAddedBg": { "dark": "#0F2020", "light": "#EDFEF5" },
    "diffRemovedBg": { "dark": "#21131B", "light": "#FEF1F0" },
    "diffContextBg": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "darkMuted", "light": "lightMuted" },
    "diffAddedLineNumberBg": { "dark": "#102F27", "light": "#DDFCEC" },
    "diffRemovedLineNumberBg": { "dark": "#31181F", "light": "#FEE5E4" },
    "markdownText": { "dark": "darkText", "light": "lightText" },
    "markdownHeading": { "dark": "uiRed", "light": "lightRed" },
    "markdownLink": { "dark": "uiCyan", "light": "lightCyan" },
    "markdownLinkText": { "dark": "uiRed", "light": "lightRed" },
    "markdownCode": { "dark": "questGold", "light": "lightYellow" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "warningOrange", "light": "lightOrange" },
    "markdownStrong": { "dark": "brandYellow", "light": "lightYellow" },
    "markdownHorizontalRule": { "dark": "darkBorder", "light": "lightBorder" },
    "markdownListItem": { "dark": "brandYellow", "light": "lightYellow" },
    "markdownListEnumeration": { "dark": "uiCyan", "light": "lightCyan" },
    "markdownImage": { "dark": "uiCyan", "light": "lightCyan" },
    "markdownImageText": { "dark": "uiRed", "light": "lightRed" },
    "markdownCodeBlock": { "dark": "darkText", "light": "lightText" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "uiRed", "light": "lightRed" },
    "syntaxFunction": { "dark": "uiCyan", "light": "lightCyan" },
    "syntaxVariable": { "dark": "darkText", "light": "lightText" },
    "syntaxString": { "dark": "questGold", "light": "lightYellow" },
    "syntaxNumber": { "dark": "warningOrange", "light": "lightOrange" },
    "syntaxType": { "dark": "typeBlue", "light": "lightBlue" },
    "syntaxOperator": { "dark": "uiRed", "light": "lightRed" },
    "syntaxPunctuation": { "dark": "darkText", "light": "lightText" }
  }
}
