{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "neonYellow": "#FCEE0A",
    "neonPink": "#FF003C",
    "neonCyan": "#00F0FF",
    "neonGreen": "#39FF14",
    "neonPurple": "#BD00FF",
    "neonOrange": "#FF9900",
    "darkBg": "#08080C",
    "darkBgPanel": "#10101A",
    "darkBgElement": "#181826",
    "darkText": "#F0F0F5",
    "darkMuted": "#7A7A8C",
    "darkBorder": "#2A2A3E",
    "darkBorderSubtle": "#1A1A28",
    "darkRed": "#FF4D6D",
    "darkYellow": "#FFD60A",
    "darkGreen": "#52B788",
    "darkBlue": "#48CAE4",
    "lightBg": "#F5F5FA",
    "lightBgPanel": "#EAEAF2",
    "lightBgElement": "#E0E0EA",
    "lightText": "#1A1A24",
    "lightMuted": "#5A5A6E",
    "lightBorder": "#B8B8C8",
    "lightBorderSubtle": "#D8D8E2",
    "lightRed": "#B83232",
    "lightYellow": "#7A5C00",
    "lightGreen": "#2A6F4D",
    "lightBlue": "#176A8C",
    "lightPurple": "#7A1FA2",
    "lightPink": "#B82E5A"
  },
  "theme": {
    "primary": { "dark": "neonYellow", "light": "lightYellow" },
    "secondary": { "dark": "neonPink", "light": "lightPink" },
    "accent": { "dark": "neonCyan", "light": "lightBlue" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkYellow", "light": "lightYellow" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkBlue", "light": "lightBlue" },
    "text": { "dark": "darkText", "light": "lightText" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkBgElement", "light": "lightBgElement" },
    "border": { "dark": "darkBorder", "light": "lightBorder" },
    "borderActive": { "dark": "neonCyan", "light": "lightBlue" },
    "borderSubtle": { "dark": "darkBorderSubtle", "light": "lightBorderSubtle" },
    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "neonPurple", "light": "lightPurple" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "#0F2A1F", "light": "#E2F5EC" },
    "diffRemovedBg": { "dark": "#2A0F17", "light": "#F9E2E5" },
    "diffContextBg": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "darkMuted", "light": "lightMuted" },
    "diffAddedLineNumberBg": { "dark": "#0C2219", "light": "#D2EBDD" },
    "diffRemovedLineNumberBg": { "dark": "#22121A", "light": "#F2D7DB" },
    "markdownText": { "dark": "darkText", "light": "lightText" },
    "markdownHeading": { "dark": "neonYellow", "light": "lightYellow" },
    "markdownLink": { "dark": "neonCyan", "light": "lightBlue" },
    "markdownLinkText": { "dark": "neonPink", "light": "lightPink" },
    "markdownCode": { "dark": "darkGreen", "light": "lightGreen" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "neonPurple", "light": "lightPurple" },
    "markdownStrong": { "dark": "neonPink", "light": "lightPink" },
    "markdownHorizontalRule": { "dark": "darkBorder", "light": "lightBorder" },
    "markdownListItem": { "dark": "neonYellow", "light": "lightYellow" },
    "markdownListEnumeration": { "dark": "neonCyan", "light": "lightBlue" },
    "markdownImage": { "dark": "neonCyan", "light": "lightBlue" },
    "markdownImageText": { "dark": "neonPink", "light": "lightPink" },
    "markdownCodeBlock": { "dark": "darkText", "light": "lightText" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "neonPink", "light": "lightPink" },
    "syntaxFunction": { "dark": "neonCyan", "light": "lightBlue" },
    "syntaxVariable": { "dark": "neonOrange", "light": "lightYellow" },
    "syntaxString": { "dark": "darkGreen", "light": "lightGreen" },
    "syntaxNumber": { "dark": "neonPurple", "light": "lightPurple" },
    "syntaxType": { "dark": "neonYellow", "light": "lightYellow" },
    "syntaxOperator": { "dark": "neonCyan", "light": "lightBlue" },
    "syntaxPunctuation": { "dark": "darkText", "light": "lightText" }
  }
}
