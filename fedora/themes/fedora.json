{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "fedoraBlue": "#3C6EB4",
    "fedoraNewBlue": "#51A2DA",
    "fedoraDarkBlue": "#294172",
    "darkBg": "#07111C",
    "darkBgPanel": "#0D1B2A",
    "darkBgElement": "#14263A",
    "darkText": "#EAF4FB",
    "darkMuted": "#88A4BB",
    "darkBorderSubtle": "#1D344C",
    "darkSky": "#8DD7F7",
    "darkRed": "#F07178",
    "darkOrange": "#F4A261",
    "darkYellow": "#E9C46A",
    "darkGreen": "#78C6A3",
    "darkCyan": "#67D5D1",
    "darkPurple": "#B8A1E3",
    "darkPink": "#F28FAD",
    "lightBg": "#FFFFFF",
    "lightBgPanel": "#F4F8FB",
    "lightBgElement": "#E8F1F7",
    "lightText": "#182A3A",
    "lightMuted": "#4F687B",
    "lightBorder": "#7895AA",
    "lightBorderSubtle": "#D4E3EE",
    "lightLineNumber": "#40596B",
    "lightPrimary": "#35639F",
    "lightAccent": "#0071B9",
    "lightRed": "#B83444",
    "lightOrange": "#975100",
    "lightYellow": "#806600",
    "lightGreen": "#217044",
    "lightCyan": "#176A8C",
    "lightPurple": "#7048A8",
    "lightPink": "#A93B66"
  },
  "theme": {
    "primary": { "dark": "fedoraNewBlue", "light": "lightPrimary" },
    "secondary": { "dark": "darkPurple", "light": "fedoraDarkBlue" },
    "accent": { "dark": "darkSky", "light": "lightAccent" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkYellow", "light": "lightOrange" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkCyan", "light": "lightCyan" },
    "text": { "dark": "darkText", "light": "lightText" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkBgElement", "light": "lightBgElement" },
    "border": { "dark": "fedoraBlue", "light": "lightBorder" },
    "borderActive": { "dark": "fedoraNewBlue", "light": "lightPrimary" },
    "borderSubtle": { "dark": "darkBorderSubtle", "light": "lightBorderSubtle" },
    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "fedoraNewBlue", "light": "lightPrimary" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "#102B2C", "light": "#E2F5EC" },
    "diffRemovedBg": { "dark": "#321C26", "light": "#FBE7EA" },
    "diffContextBg": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "darkMuted", "light": "lightLineNumber" },
    "diffAddedLineNumberBg": { "dark": "#0C2224", "light": "#D2EBDD" },
    "diffRemovedLineNumberBg": { "dark": "#281821", "light": "#F2D7DB" },
    "markdownText": { "dark": "darkText", "light": "lightText" },
    "markdownHeading": { "dark": "fedoraNewBlue", "light": "lightPrimary" },
    "markdownLink": { "dark": "darkSky", "light": "lightAccent" },
    "markdownLinkText": { "dark": "darkCyan", "light": "lightCyan" },
    "markdownCode": { "dark": "darkGreen", "light": "lightGreen" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "darkYellow", "light": "lightYellow" },
    "markdownStrong": { "dark": "fedoraNewBlue", "light": "fedoraDarkBlue" },
    "markdownHorizontalRule": { "dark": "fedoraBlue", "light": "lightBorder" },
    "markdownListItem": { "dark": "fedoraNewBlue", "light": "lightPrimary" },
    "markdownListEnumeration": { "dark": "darkCyan", "light": "lightCyan" },
    "markdownImage": { "dark": "darkSky", "light": "lightAccent" },
    "markdownImageText": { "dark": "darkCyan", "light": "lightCyan" },
    "markdownCodeBlock": { "dark": "darkText", "light": "lightText" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "darkPurple", "light": "lightPurple" },
    "syntaxFunction": { "dark": "fedoraNewBlue", "light": "lightPrimary" },
    "syntaxVariable": { "dark": "darkOrange", "light": "lightOrange" },
    "syntaxString": { "dark": "darkGreen", "light": "lightGreen" },
    "syntaxNumber": { "dark": "darkYellow", "light": "lightYellow" },
    "syntaxType": { "dark": "darkCyan", "light": "lightCyan" },
    "syntaxOperator": { "dark": "darkPink", "light": "lightPink" },
    "syntaxPunctuation": { "dark": "darkText", "light": "lightText" }
  }
}
