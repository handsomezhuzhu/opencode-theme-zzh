{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "fedoraBlue": "#3C6EB4",
    "fedoraNewBlue": "#51A2DA",
    "fedoraDarkBlue": "#294172",
    "freedomPurple": "#A07CBC",
    "friendsMagenta": "#DB3279",
    "featuresOrange": "#E59728",
    "firstGreen": "#79DB32",
    "fedoraBlueMuted": "#6F81A6",
    "fedoraBlueSoft": "#8FAED9",
    "fedoraBluePale": "#AAD0EE",
    "fedoraBlueWash": "#E8EFF8",
    "freedomPurpleSoft": "#CFBDDD",
    "friendsMagentaSoft": "#ED97BB",
    "featuresOrangeSoft": "#F2CA92",
    "firstGreenSoft": "#BBED97",
    "darkBg": "#07111C",
    "darkBgPanel": "#0D1B2A",
    "darkBgElement": "#14263A",
    "darkText": "#E8EFF8",
    "darkMuted": "#8FAED9",
    "darkBorderSubtle": "#1D344C",
    "darkRed": "#F07178",
    "lightBg": "#FFFFFF",
    "lightBgPanel": "#F4F8FB",
    "lightBgElement": "#E8EFF8",
    "lightText": "#1D252E",
    "lightMuted": "#4C4C4C",
    "lightBorderSubtle": "#D4E3EE",
    "lightLineNumber": "#40596B",
    "lightPrimary": "#35639F",
    "lightAccent": "#0071B9",
    "lightRed": "#B83444",
    "lightOrange": "#975100",
    "lightYellow": "#806600",
    "lightGreen": "#217044",
    "lightCyan": "#176A8C",
    "lightPurple": "#7048A8",
    "lightPink": "#A93B66"
  },
  "theme": {
    "primary": { "dark": "fedoraNewBlue", "light": "fedoraDarkBlue" },
    "secondary": { "dark": "freedomPurpleSoft", "light": "lightPurple" },
    "accent": { "dark": "fedoraBluePale", "light": "lightPrimary" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "featuresOrangeSoft", "light": "lightOrange" },
    "success": { "dark": "firstGreenSoft", "light": "lightGreen" },
    "info": { "dark": "fedoraBluePale", "light": "lightCyan" },
    "text": { "dark": "darkText", "light": "lightText" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkBgElement", "light": "lightBgElement" },
    "border": { "dark": "fedoraBlueMuted", "light": "fedoraBlue" },
    "borderActive": { "dark": "fedoraNewBlue", "light": "fedoraDarkBlue" },
    "borderSubtle": { "dark": "darkBorderSubtle", "light": "lightBorderSubtle" },
    "diffAdded": { "dark": "firstGreenSoft", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "fedoraNewBlue", "light": "fedoraDarkBlue" },
    "diffHighlightAdded": { "dark": "firstGreenSoft", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "#102B2C", "light": "#E2F5EC" },
    "diffRemovedBg": { "dark": "#321C26", "light": "#FBE7EA" },
    "diffContextBg": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "darkMuted", "light": "lightLineNumber" },
    "diffAddedLineNumberBg": { "dark": "#0C2224", "light": "#D2EBDD" },
    "diffRemovedLineNumberBg": { "dark": "#281821", "light": "#F2D7DB" },
    "markdownText": { "dark": "darkText", "light": "lightText" },
    "markdownHeading": { "dark": "fedoraNewBlue", "light": "fedoraDarkBlue" },
    "markdownLink": { "dark": "fedoraBluePale", "light": "lightPrimary" },
    "markdownLinkText": { "dark": "friendsMagentaSoft", "light": "lightPink" },
    "markdownCode": { "dark": "firstGreenSoft", "light": "lightGreen" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "featuresOrangeSoft", "light": "lightYellow" },
    "markdownStrong": { "dark": "fedoraNewBlue", "light": "fedoraDarkBlue" },
    "markdownHorizontalRule": { "dark": "fedoraBlueMuted", "light": "fedoraBlue" },
    "markdownListItem": { "dark": "fedoraNewBlue", "light": "fedoraDarkBlue" },
    "markdownListEnumeration": { "dark": "friendsMagentaSoft", "light": "lightPink" },
    "markdownImage": { "dark": "fedoraBluePale", "light": "lightPrimary" },
    "markdownImageText": { "dark": "friendsMagentaSoft", "light": "lightPink" },
    "markdownCodeBlock": { "dark": "darkText", "light": "lightText" },
    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "freedomPurpleSoft", "light": "lightPurple" },
    "syntaxFunction": { "dark": "fedoraNewBlue", "light": "lightPrimary" },
    "syntaxVariable": { "dark": "featuresOrangeSoft", "light": "lightOrange" },
    "syntaxString": { "dark": "firstGreenSoft", "light": "lightGreen" },
    "syntaxNumber": { "dark": "featuresOrange", "light": "lightYellow" },
    "syntaxType": { "dark": "fedoraBluePale", "light": "lightCyan" },
    "syntaxOperator": { "dark": "friendsMagentaSoft", "light": "lightPink" },
    "syntaxPunctuation": { "dark": "darkText", "light": "lightText" }
  }
}
